{
  "name": "your-app-tools",
  "version": "1.0.0",
  "base_url": "https://<your-domain>/v1",
  "auth": {
    "type": "bearer",
    "header": "Authorization"
  },
  "tools": [
    {
      "name": "search_[RESOURCE_NAME]s",
      "method": "GET",
      "path": "/search",
      "description": "Searches domain records by keyword. Use this before creating to avoid duplicates.",
      "input_schema": {
        "type": "object",
        "required": ["tenant_id", "q"],
        "properties": {
          "tenant_id": { "type": "string" },
          "q": { "type": "string", "description": "Search query." },
          "types": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Filter by specific resource types (e.g. ['invoice', 'customer'])."
          },
          "limit": { "type": "integer", "default": 10, "maximum": 50 }
        }
      }
    },
    {
      "name": "create_[RESOURCE_NAME]",
      "method": "POST",
      "path": "/[RESOURCE_NAME]s",
      "description": "Creates a new domain record directly. Requires write:[RESOURCE_NAME]s scope.",
      "input_schema": {
        "type": "object",
        "required": ["tenant_id", "[REQUIRED_FIELD_1]", "[REQUIRED_FIELD_2]"],
        "properties": {
          "tenant_id": { "type": "string" },
          "[REQUIRED_FIELD_1]": { "type": "string", "description": "Derived from Phase 1 specific discovery." },
          "[OPTIONAL_FIELD]": { "type": "string", "description": "Derived from Phase 1 specific discovery." },
          "metadata": { "type": "object", "description": "agent_name, trace_id for audit logs." }
        }
      }
    },
    {
      "name": "update_[RESOURCE_NAME]",
      "method": "PATCH",
      "path": "/[RESOURCE_NAME]s/{id}",
      "description": "Updates specific fields on an existing record. Requires write:[RESOURCE_NAME]s scope.",
      "input_schema": {
        "type": "object",
        "required": ["tenant_id", "id", "patch"],
        "properties": {
          "tenant_id": { "type": "string" },
          "id": { "type": "string", "description": "The ID of the record to update." },
          "patch": {
            "type": "object",
            "description": "Partial update fields matching the discovered schema constraint."
          }
        }
      }
    },
    {
      "name": "create_link",
      "method": "POST",
      "path": "/links",
      "description": "Links two domain records together with a named relation (if applicable to the domain). Requires write:links scope.",
      "input_schema": {
        "type": "object",
        "required": ["tenant_id", "from_id", "to_id", "relation"],
        "properties": {
          "tenant_id": { "type": "string" },
          "from_id": { "type": "string" },
          "to_id": { "type": "string" },
          "relation": {
            "type": "string",
            "description": "The discovered relationship between the two records (e.g., 'billed_to')."
          }
        }
      }
    }
  ]
}
